modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "Invoice Scanner Service"
APP_ENV = "development"
OPENAI_MODEL = "gpt-4.1-mini"
UPLOAD_DIR = "./data/uploads"
EXPORT_DIR = "./data/exports"
USE_OPENAI = "true"
OCR_PROVIDER = "ocr_space"
OCR_SPACE_API_KEY = "K83458619788957"
OCR_SPACE_ENDPOINT = "https://api.ocr.space/parse/image"
OCR_SPACE_LANGUAGE = "auto"
OCR_SPACE_OVERLAY_REQUIRED = "false"
OCR_SPACE_SCALE = "true"
OCR_SPACE_OCR_ENGINE = "2"
OCR_SPACE_TIMEOUT_SECONDS = "90"
ENABLE_PADDLE_OCR = "false"
