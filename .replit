modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "gumbo", "harfbuzz", "jbig2dec", "lcms2", "libimagequant", "libjpeg", "libjpeg_turbo", "libtiff", "libwebp", "libxcrypt", "mupdf", "openjpeg", "postgresql", "swig", "tcl", "tk", "xcbuild", "zlib"]

[userenv]

[userenv.shared]
APP_NAME = "Invoice Scanner Service"
APP_ENV = "development"
OPENAI_MODEL = "gpt-4.1-mini"
UPLOAD_DIR = "./data/uploads"
EXPORT_DIR = "./data/exports"
USE_OPENAI = "true"
OCR_PROVIDER = "ocr_space"
OCR_SPACE_API_KEY = "K83458619788957"
OCR_SPACE_ENDPOINT = "https://api.ocr.space/parse/image"
OCR_SPACE_LANGUAGE = "auto"
OCR_SPACE_OVERLAY_REQUIRED = "false"
OCR_SPACE_SCALE = "true"
OCR_SPACE_OCR_ENGINE = "2"
OCR_SPACE_TIMEOUT_SECONDS = "90"
ENABLE_PADDLE_OCR = "false"
AZURE_DI_ENDPOINT = "https://approvlinq.cognitiveservices.azure.com/"
USE_AZURE_DI = "true"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ApprovLinq && uvicorn app.main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd ApprovLinq && uvicorn app.main:app --host 0.0.0.0 --port 5000"]
